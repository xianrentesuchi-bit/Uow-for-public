{
  "compilerOptions": {
    "target": "ES2020",

    "useDefineForClassFields": true,

    "module": "ESNext",

    "moduleResolution": "Bundler",

    "strict": true,

    "jsx": "preserve",

    "sourceMap": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "noEmit": true,

    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],

    "types": [
      "node"
    ]
  },

  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ]
}
